FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml /app/pyproject.toml
RUN pip install --no-cache-dir --upgrade pip

COPY . /app
RUN pip install --no-cache-dir \
    celery \
    redis \
    sqlalchemy \
    psycopg[binary] \
    pydantic \
    pydantic-settings

CMD ["celery", "-A", "app.workers.celery_app.celery_app", "worker", "--loglevel=info"]
